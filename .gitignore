bin/
dist/
vendor/
*.test
*.out
.idea/
.vscode/
*.swp
.DS_Store

# Go workspace files (not used by this module)
go.work
go.work.sum

# Local profiles & runtime data
profiles.toml
audit.jsonl
.worktrees/

# gno skill eval scaffolding (RED findings, baseline-vs-skill transcripts, fixtures):
# kept local for skill development, not part of the distributed skill.
skills/gno/tests/

# playground/.claude ships the e2e driver skill + agent (dev tooling deliverables);
# re-include it over machine-global ".claude" ignores, keeping local settings out.
!playground/.claude/
playground/.claude/settings.local.json

# Repo-root .claude is otherwise machine-global-ignored; re-include only the
# playground-driver symlink so the skill surfaces from the repo root too, keeping
# local settings.json and agent-memory out.
!.claude/
.claude/*
!.claude/skills/
.claude/skills/*
!.claude/skills/playground-driver

# CLAUDE.md is machine-global-ignored (the repo uses AGENTS.md); re-include the
# CLAUDE.md → AGENTS.md symlinks so Claude auto-loads the AGENTS guidance — at the
# repo root and when cwd is playground/.
!/CLAUDE.md
!playground/CLAUDE.md
